{
  "name": "codeforge",
  "private": true,
  "workspaces": [
    "anvil",
    "forge"
  ],
  "scripts": {
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "lint": "npm run lint --workspaces",
    "type-check": "npm run type-check --workspaces"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^18.6.1",
    "commitlint": "^18.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5"
  }
}
